{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Screenshot Translator",
  "version": "0.1.0",
  "identifier": "com.local.desktop-screenshot-translator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop Screenshot Translator",
        "width": 1180,
        "height": 780,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
